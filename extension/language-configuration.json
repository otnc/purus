{
  "comments": {
    "lineComment": "--",
    "blockComment": ["---", "---"]
  },
  "brackets": [
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "///", "close": "///" },
    { "open": "//;", "close": ";//" }
  ],
  "surroundingPairs": [
    ["[", "]"]
  ],
  "folding": {
    "offSide": true
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(fn|if|elif|else|unless|while|until|do|for|match|when|switch|case|try|catch|finally|mod|class)\\b.*$",
    "decreaseIndentPattern": "^\\s*(elif|else|when|catch|finally)\\b"
  },
  "wordPattern": "[a-zA-Z][a-zA-Z0-9-]*"
}
